# ============================================================
# SmartScrape Pro - Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# App
APP_NAME=SmartScrape Pro
APP_ENV=development          # development | production
APP_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
DEBUG=true

# Database
# Dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./database/smartscrape.db
# Prod (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/smartscrape

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (create these in Stripe dashboard)
STRIPE_BASIC_PRICE_ID=price_basic_monthly
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_BUSINESS_PRICE_ID=price_business_monthly

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Admin
ADMIN_EMAIL=admin@smartscrapepro.com
ADMIN_PASSWORD=AdminPass123!

# File Upload
UPLOAD_DIR=./exports/uploads
MAX_UPLOAD_SIZE_MB=10

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Scraping
SCRAPE_TIMEOUT_SECONDS=30
MAX_CONCURRENT_JOBS=5

# Plans — Job Limits
BASIC_JOBS_PER_MONTH=10
PRO_JOBS_PER_MONTH=100
BUSINESS_JOBS_PER_MONTH=999999
